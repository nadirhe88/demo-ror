<% content_for :title, "Posts" %>

<h1 class="mb-4">Posts</h1>

<!-- Mostrar flash notice si existe -->
<% if notice.present? %>
  <div class="alert alert-success">
    <%= notice %>
  </div>
<% end %>

<div class="mb-3">
  <%= link_to "Nuevo Post", new_post_path, class: "btn btn-success" %>
</div>

<table class="table table-striped table-hover">
  <thead class="table-dark">
    <tr>
      <th>Título</th>
      <th>Pregunta</th>
      <th>Respuesta</th>
      <th>Creación</th>
      <th>Acciones</th>
    </tr>
  </thead>
  <tbody>
    <% @posts.each do |post| %>
      <tr>
        <td><%= post.titulo %></td>
        <td><%= truncate(post.pregunta, length: 50) %></td>
        <td><%= truncate(post.respuesta, length: 50) %></td>
        <td><%= post.created_at.strftime("%d/%m/%Y %H:%M") %></td>
        <td>
          <%= link_to "Ver", post_path(post), class: "btn btn-sm btn-primary" %>
          <!-- NO mostramos “Editar” ni “Eliminar” -->
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
